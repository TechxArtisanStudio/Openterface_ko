---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="비디오"
  description="YouTube에서 만나는 Openterface 제품 데모, 튜토리얼 및 리뷰."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="비디오 파이프라인을 포팅하는 동안 전체 YouTube 비디오 그리드는 레거시 사이트에서 확인하실 수 있습니다." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">비디오</h1>
      <p class="mt-4 text-lg text-muted">
        Openterface KVM 및 KeyMod 제품에 대한 제품 데모, 설정 가이드 및 커뮤니티 리뷰를 시청하세요.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        모든 비디오 찾아보기 →
      </a>
    </div>
  </section>
</BaseLayout>
