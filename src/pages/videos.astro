---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoCatalog from '../components/VideoCatalog.astro';
import { siteConfig } from '../config/site';
import { getVideosStrings } from '../i18n/videos';
import { pageOgImages } from '../lib/seo';

const strings = getVideosStrings(siteConfig.locale);
---

<BaseLayout
  title={strings.title}
  description={strings.subtitle}
  ogImage={pageOgImages.videos}
  ogImageAlt="YouTube의 Openterface KVM 제품 데모 및 커뮤니티 리뷰"
  canonicalPath="/videos/"
>
  <VideoCatalog />
</BaseLayout>
