---
import { docsPath, siteConfig } from '../config/site';
import Logo from './Logo.astro';
import FooterNewsletter from './FooterNewsletter.astro';
---

<footer class="border-t border-gray-200 bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <Logo variant="default" class="h-7" />
        <p class="mt-3 text-sm text-muted">IT 전문가를 위한 초소형 KVM-over-USB 솔루션.</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">제품</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/products/keymod/" class="text-muted hover:text-primary-dark">KeyMod 시리즈</a></li>
          <li><a href="/products/kvm-go/" class="text-muted hover:text-primary-dark">KVM-GO 시리즈</a></li>
          <li><a href="/products/minikvm/" class="text-muted hover:text-primary-dark">Mini-KVM</a></li>
          <li><a href="/products/accessories/" class="text-muted hover:text-primary-dark">액세서리</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">리소스</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/videos/" class="text-muted hover:text-primary-dark">비디오</a></li>
          <li><a href={docsPath('/faq/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">FAQ</a></li>
          <li><a href={docsPath('/app/overview/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">앱</a></li>
          <li><a href={docsPath('/support/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">지원</a></li>
        </ul>
      </div>
    </div>

    <FooterNewsletter
      title="뉴스레터"
      description="제품, 펌웨어, KVM 팁에 대한 월간 업데이트."
      submitLabel="구독"
      namePlaceholder="이름"
      emailPlaceholder="이메일 *"
      footnote="언제든지 구독 취소 가능."
    />

    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-muted">
      <p>© {new Date().getFullYear()} Openterface. 오픈 소스 KVM-over-USB.</p>
      <p class="mt-1">
        <a href={siteConfig.legacyUrl + '/policy/privacy/'} class="hover:text-primary-dark" target="_blank" rel="noopener">개인정보 보호정책</a>
        ·
        <a href={siteConfig.legacyUrl + '/policy/terms-of-service/'} class="hover:text-primary-dark" target="_blank" rel="noopener">서비스 약관</a>
        {siteConfig.analytics.enabled && (
          <>
            ·
            <a href="#" id="cookie-settings" class="hover:text-primary-dark">{siteConfig.analytics.consent.cookieLabel}</a>
          </>
        )}
      </p>
    </div>
  </div>
</footer>
